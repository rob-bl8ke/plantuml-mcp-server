# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real token.

# Required: GitHub Personal Access Token (no scopes needed)
# Used by the mcp-server container to call the GitHub Models API.
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional: GitHub Models model name (default: gpt-4o-mini)
# GITHUB_MODEL=gpt-4o-mini
